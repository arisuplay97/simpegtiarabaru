// prisma/schema.prisma — Schema lengkap dengan semua field baru

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ USER & AUTH ============
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      Role     @default(PEGAWAI)
  pegawai   Pegawai?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============ BIDANG / UNIT KERJA ============
model Bidang {
  id              String      @id @default(cuid())
  nama            String      @unique
  kode            String      @unique
  kepalaBidang    String
  direkturAtasan  String
  aktif           Boolean     @default(true)
  pegawai         Pegawai[]
  subBidang       SubBidang[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

// ============ SUB BIDANG ============
model SubBidang {
  id        String    @id @default(cuid())
  nama      String
  bidangId  String
  bidang    Bidang    @relation(fields: [bidangId], references: [id], onDelete: Cascade)
  pegawai   Pegawai[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([bidangId, nama])
}

// ============ PEGAWAI ============
model Pegawai {
  id                    String    @id @default(cuid())
  nik                   String    @unique  // NIK KTP 16 digit
  nama                  String
  email                 String    @unique
  telepon               String?
  fotoUrl               String?   // URL foto dari Vercel Blob

  // Kepegawaian
  bidangId              String?
  bidang                Bidang?     @relation(fields: [bidangId], references: [id])
  subBidangId           String?
  subBidang             SubBidang?  @relation(fields: [subBidangId], references: [id])
  jabatan               String
  tipeJabatan           TipeJabatan @default(STAFF)
  golongan              String    // Format: A/I, B/II, dst
  pangkat               String?
  atasanLangsung        String?
  status                StatusPegawai @default(AKTIF)
  sp                    StatusSP?
  tanggalMasuk          DateTime

  // Data Pribadi
  jenisKelamin          JenisKelamin?
  tempatLahir           String?
  tanggalLahir          DateTime?
  agama                 Agama?
  statusNikah           StatusNikah?
  alamat                String?
  npwp                  String?

  // Pendidikan
  pendidikanTerakhir    TingkatPendidikan?
  jurusan               String?
  institusi             String?
  tahunLulus            String?

  // Keuangan
  bank                  String?
  noRekening            String?
  bpjsKesehatan         String?
  bpjsKetenagakerjaan   String?

  // Relasi ke User auth
  userId                String    @unique
  user                  User      @relation(fields: [userId], references: [id])

  // Relasi ke modul lain
  absensi               Absensi[]
  cuti                  Cuti[]
  payroll               Payroll[]
  kpi                   KPI[]
  mutasiDari            Mutasi[]  @relation("MutasiDari")
  mutasiKe              Mutasi[]  @relation("MutasiKe")
  slipGaji              SlipGaji[]

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

// ============ MUTASI ============
model Mutasi {
  id              String        @id @default(cuid())
  pegawaiId       String
  pegawai         Pegawai       @relation("MutasiDari", fields: [pegawaiId], references: [id])
  approvedById    String?
  approvedBy      Pegawai?      @relation("MutasiKe", fields: [approvedById], references: [id])

  type            TipeMutasi
  jabatanAsal     String
  unitAsal        String
  jabatanTujuan   String
  unitTujuan      String
  alasan          String
  tanggalEfektif  DateTime
  status          StatusMutasi  @default(PENDING)
  nomorSK         String?
  catatan         String?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

// ============ ABSENSI ============
model Absensi {
  id        String        @id @default(cuid())
  pegawaiId String
  tanggal   DateTime
  status    StatusAbsensi
  jamMasuk  DateTime?
  jamKeluar DateTime?
  pegawai   Pegawai       @relation(fields: [pegawaiId], references: [id])
  createdAt DateTime      @default(now())
}

// ============ CUTI ============
model Cuti {
  id             String     @id @default(cuid())
  pegawaiId      String
  tanggalMulai   DateTime
  tanggalSelesai DateTime
  jenisCuti      String
  status         StatusCuti @default(PENDING)
  alasan         String
  pegawai        Pegawai    @relation(fields: [pegawaiId], references: [id])
  createdAt      DateTime   @default(now())
}

// ============ PAYROLL ============
model Payroll {
  id        String   @id @default(cuid())
  pegawaiId String
  bulan     DateTime
  gajiPokok Decimal
  tunjangan Decimal
  potongan  Decimal
  total     Decimal
  pegawai   Pegawai  @relation(fields: [pegawaiId], references: [id])
  createdAt DateTime @default(now())
}

// ============ KPI ============
model KPI {
  id        String   @id @default(cuid())
  pegawaiId String
  tahun     String
  nilai     Decimal
  pegawai   Pegawai  @relation(fields: [pegawaiId], references: [id])
  createdAt DateTime @default(now())
}

// ============ SLIP GAJI ============
model SlipGaji {
  id        String   @id @default(cuid())
  pegawaiId String
  bulan     DateTime
  fileUrl   String
  pegawai   Pegawai  @relation(fields: [pegawaiId], references: [id])
  createdAt DateTime @default(now())
}

// ============ ENUMS ============

enum Role {
  SUPERADMIN
  HRD
  DIREKSI
  PEGAWAI
}

enum TipeJabatan {
  KEPALA_BIDANG
  KASUBBID
  STAFF
  KONTRAK
}

enum StatusPegawai {
  AKTIF
  CUTI
  NON_AKTIF
  PENSIUN
}

enum StatusSP {
  SP1
  SP2
  SP3
}

enum JenisKelamin {
  L
  P
}

enum Agama {
  ISLAM
  KRISTEN
  KATOLIK
  HINDU
  BUDDHA
  KONGHUCU
}

enum StatusNikah {
  BELUM_MENIKAH
  MENIKAH
  CERAI
}

enum TingkatPendidikan {
  SD
  SMP
  SMA
  D1
  D2
  D3
  D4
  S1
  S2
  S3
}

enum TipeMutasi {
  MUTASI
  PROMOSI
  DEMOSI
  ROTASI
}

enum StatusMutasi {
  PENDING
  APPROVED
  REJECTED
}

enum StatusAbsensi {
  HADIR
  TERLAMBAT
  ALPA
  CUTI
  SAKIT
}

enum StatusCuti {
  PENDING
  APPROVED
  REJECTED
}
