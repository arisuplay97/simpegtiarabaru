// prisma/schema.prisma — Schema lengkap dengan semua field baru

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ USER & AUTH ============
model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  password           String
  role               Role     @default(PEGAWAI)
  mustChangePassword Boolean  @default(true)
  pegawai            Pegawai?
  notifikasi         Notifikasi[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// ============ BIDANG / UNIT KERJA ============
model Bidang {
  id              String      @id @default(cuid())
  nama            String      @unique
  kode            String      @unique
  kepalaBidang    String
  direkturAtasan  String
  aktif           Boolean     @default(true)
  pegawai         Pegawai[]
  subBidang       SubBidang[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

// ============ SUB BIDANG ============
model SubBidang {
  id        String    @id @default(cuid())
  nama      String
  bidangId  String
  bidang    Bidang    @relation(fields: [bidangId], references: [id], onDelete: Cascade)
  pegawai   Pegawai[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([bidangId, nama])
}

// ============ PEGAWAI ============
model Pegawai {
  id                    String    @id @default(cuid())
  nik                   String    @unique  // NIK KTP 16 digit
  nama                  String
  email                 String    @unique
  telepon               String?
  fotoUrl               String?   // URL foto dari Vercel Blob

  // Kepegawaian
  bidangId              String?
  bidang                Bidang?     @relation(fields: [bidangId], references: [id])
  subBidangId           String?
  subBidang             SubBidang?  @relation(fields: [subBidangId], references: [id])
  jabatan               String
  saldoCuti             Int         @default(12)
  gajiPokok             Decimal     @default(0)
  tunjangan             Decimal     @default(0)
  tipeJabatan           TipeJabatan @default(STAFF)
  golongan              String    // Format: A/I, B/II, dst
  pangkat               String?
  atasanLangsung        String?
  status                StatusPegawai @default(AKTIF)
  sp                    StatusSP?
  tanggalMasuk          DateTime

  // Toggle bebas absensi & Binding lokasi
  bebasAbsensi          Boolean   @default(false)
  lokasiAbsensiId       String?
  lokasiAbsensi         LokasiAbsensi? @relation(fields: [lokasiAbsensiId], references: [id])

  // Data Pribadi
  jenisKelamin          JenisKelamin?
  tempatLahir           String?
  tanggalLahir          DateTime?
  agama                 Agama?
  statusNikah           StatusNikah?
  alamat                String?
  npwp                  String?

  // Pendidikan
  pendidikanTerakhir    TingkatPendidikan?
  jurusan               String?
  institusi             String?
  tahunLulus            String?

  // Keuangan
  bank                  String?
  noRekening            String?
  bpjsKesehatan         String?
  bpjsKetenagakerjaan   String?

  // Relasi ke User auth
  userId                String    @unique
  user                  User      @relation(fields: [userId], references: [id])

  // Relasi ke modul lain
  deviceId              String?   // UUID Perangkat Utama Pegawai
  absensi               Absensi[]
  cuti                  Cuti[]
  payroll               Payroll[]
  kpi                   KPI[]
  mutasiDari            Mutasi[]  @relation("MutasiDari")
  mutasiKe              Mutasi[]  @relation("MutasiKe")
  slipGaji              SlipGaji[]
  
  // Phase 4 New Relations
  kgb                   KGB[]
  riwayatPangkat        KenaikanPangkat[]
  suratPeringatan       SuratPeringatan[]
  keluarga              PegawaiKeluarga[]
  pendidikan            PegawaiPendidikan[]
  riwayatJabatan        PegawaiJabatan[]
  riwayatPangkatDetail  PegawaiPangkat[]
  pelatihan             PegawaiPelatihan[]
  dokumen               PegawaiDokumen[]
  
  // Update New Features
  jadwalShift           JadwalShift[]
  lembur                Lembur[]
  pph21                 PPh21[]
  kontrak               Kontrak[]
  
  // Reward & Points
  penukaranPoin         PenukaranPoin[]
  poinDiAcc             PenukaranPoin[] @relation("PoinApprovedBy")

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

// ============ MUTASI ============
model Mutasi {
  id              String        @id @default(cuid())
  pegawaiId       String
  pegawai         Pegawai       @relation("MutasiDari", fields: [pegawaiId], references: [id])
  approvedById    String?
  approvedBy      Pegawai?      @relation("MutasiKe", fields: [approvedById], references: [id])

  type            TipeMutasi
  jabatanAsal     String
  unitAsal        String
  jabatanTujuan   String
  unitTujuan      String
  alasan          String
  tanggalEfektif  DateTime
  status          StatusMutasi  @default(PENDING)
  nomorSK         String?
  catatan         String?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

// ============ ABSENSI ============
model Absensi {
  id        String          @id @default(cuid())
  pegawaiId String
  tanggal   DateTime
  status    StatusAbsensi
  metode    MetodeAbsensi   @default(SELFIE)
  importId  String?
  jamMasuk  DateTime?
  jamKeluar DateTime?
  pegawai   Pegawai         @relation(fields: [pegawaiId], references: [id])
  import    ImportFingerprint? @relation(fields: [importId], references: [id], onDelete: SetNull)
  createdAt DateTime        @default(now())
}

// ============ CUTI ============
model Cuti {
  id             String     @id @default(cuid())
  pegawaiId      String
  tanggalMulai   DateTime
  tanggalSelesai DateTime
  jenisCuti      String
  status         StatusCuti @default(PENDING)
  alasan         String
  pegawai        Pegawai    @relation(fields: [pegawaiId], references: [id])
  createdAt      DateTime   @default(now())
}

// ============ PAYROLL ============
model Payroll {
  id        String   @id @default(cuid())
  pegawaiId String
  bulan     DateTime
  gajiPokok Decimal
  tunjangan Decimal
  potongan  Decimal
  total     Decimal
  pegawai   Pegawai  @relation(fields: [pegawaiId], references: [id])
  createdAt DateTime @default(now())
}

// ============ KPI ============
model KPI {
  id        String   @id @default(cuid())
  pegawaiId String
  tahun     String
  nilai     Decimal
  pegawai   Pegawai  @relation(fields: [pegawaiId], references: [id])
  createdAt DateTime @default(now())
}

// ============ SLIP GAJI ============
model SlipGaji {
  id        String   @id @default(cuid())
  pegawaiId String
  bulan     DateTime
  fileUrl   String
  pegawai   Pegawai  @relation(fields: [pegawaiId], references: [id])
  createdAt DateTime @default(now())
}

// ============ ENUMS ============

enum Role {
  SUPERADMIN
  HRD
  DIREKSI
  PEGAWAI
}

enum TipeJabatan {
  KEPALA_BIDANG
  KASUBBID
  STAFF
  KONTRAK
  KEPALA_CABANG
  KASUBBID_CABANG
  STAFF_CABANG
}

enum StatusPegawai {
  AKTIF
  CUTI
  NON_AKTIF
  PENSIUN
}

enum StatusSP {
  SP1
  SP2
  SP3
}

enum JenisKelamin {
  L
  P
}

enum Agama {
  ISLAM
  KRISTEN
  KATOLIK
  HINDU
  BUDDHA
  KONGHUCU
}

enum StatusNikah {
  BELUM_MENIKAH
  MENIKAH
  CERAI
}

enum TingkatPendidikan {
  SD
  SMP
  SMA
  D1
  D2
  D3
  D4
  S1
  S2
  S3
}

enum TipeMutasi {
  MUTASI
  PROMOSI
  DEMOSI
  ROTASI
}

enum StatusMutasi {
  PENDING
  APPROVED
  REJECTED
}

enum StatusAbsensi {
  HADIR
  TERLAMBAT
  ALPA
  CUTI
  SAKIT
  IZIN
}

enum StatusCuti {
  PENDING
  APPROVED
  REJECTED
}

enum StatusPengajuan {
  PENDING
  APPROVED
  REJECTED
}

// ============ LOKASI ABSENSI (GEO-FENCING) ============
model LokasiAbsensi {
  id              String    @id @default(cuid())
  nama            String
  tipe            String    // kantor_pusat, kantor_cabang, acara
  alamat          String
  latitude        Float
  longitude       Float
  radius          Int       @default(100)    // dalam meter
  aktif           Boolean   @default(true)
  tanggalMulai    String?   // YYYY-MM-DD, khusus acara
  tanggalSelesai  String?   // YYYY-MM-DD, khusus acara
  wajibHadir      Boolean   @default(false)
  targetPegawai   String?   // "pusat" | "cabang" | "semua" — khusus acara wajib hadir
  keterangan      String?
  
  pegawai         Pegawai[] // Relasi balik untuk binding lokasi
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ============ PENGATURAN UMUM ============
model Pengaturan {
  id                String   @id @default("1")
  // Konfigurasi Gaji & Penalti
  
  // Absensi
  jamMasuk          String   @default("08:00")
  jamPulang         String   @default("17:00")
  batasCheckin      String   @default("16:00")
  batasTerlambat    Int      @default(15)
  lokasiPusat       String?
  
  // Cuti
  jatahCutiTahunan  Int      @default(12)
  batasBawaCuti     Int      @default(0)

  // Payroll
  tanggalGajian           Int      @default(25)
  bpjsKesehatanPcs        Float    @default(1.0)
  bpjsTkPcs               Float    @default(2.0)
  dendaTerlambat          Int      @default(5000)
  batasTerlambatDenda     Int      @default(5)
  dendaAlpa               Int      @default(7500)
  tunjanganTransport      Int      @default(120000)
  batasAlpaDendaTransport Int      @default(3)

  // Organisasi
  namaPerusahaan    String   @default("Tirta Ardhia Rinjani")
  alamatPerusahaan  String?
  logoUrl           String?

  // Dokumen
  formatNomorSK     String   @default("SK/[NOMOR]/[BULAN]/[TAHUN]")
  namaPenandatangan String   @default("Direktur Utama")

  updatedAt         DateTime @updatedAt
}

// ============ KGB (Kenaikan Gaji Berkala) ============
model KGB {
  id              String   @id @default(cuid())
  pegawaiId       String
  tanggalBerlaku  DateTime
  gajiPokokLama   Decimal
  gajiPokokBaru   Decimal
  status          StatusPengajuan @default(PENDING)
  keterangan      String?
  pegawai         Pegawai  @relation(fields: [pegawaiId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============ KENAIKAN PANGKAT ============
model KenaikanPangkat {
  id              String   @id @default(cuid())
  pegawaiId       String
  pangkatLama     String
  pangkatBaru     String
  golonganLama    String
  golonganBaru    String
  tanggalBerlaku  DateTime
  status          StatusPengajuan @default(PENDING)
  keterangan      String?
  pegawai         Pegawai  @relation(fields: [pegawaiId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============ SURAT PERINGATAN (SP) ============
model SuratPeringatan {
  id              String   @id @default(cuid())
  pegawaiId       String
  jenis           StatusSP
  alasan          String
  tanggalDiberikan DateTime
  berlakuHingga   DateTime
  pegawai         Pegawai  @relation(fields: [pegawaiId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============ PROFIL: KELUARGA ============
model PegawaiKeluarga {
  id              String   @id @default(cuid())
  pegawaiId       String
  nama            String
  hubungan        String
  pekerjaan       String?
  telepon         String?
  pegawai         Pegawai  @relation(fields: [pegawaiId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============ PROFIL: PENDIDIKAN ============
model PegawaiPendidikan {
  id              String   @id @default(cuid())
  pegawaiId       String
  tingkat         TingkatPendidikan
  institusi       String
  jurusan         String?
  tahunLulus      String
  pegawai         Pegawai  @relation(fields: [pegawaiId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============ PROFIL: JABATAN ============
model PegawaiJabatan {
  id              String   @id @default(cuid())
  pegawaiId       String
  jabatan         String
  unitDefinitif   String
  tanggalMulai    DateTime
  tanggalSelesai  DateTime?
  pegawai         Pegawai  @relation(fields: [pegawaiId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============ PROFIL: PANGKAT ============
model PegawaiPangkat {
  id              String   @id @default(cuid())
  pegawaiId       String
  pangkat         String
  golongan        String
  tanggalBerlaku  DateTime
  nomorSK         String?
  pegawai         Pegawai  @relation(fields: [pegawaiId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============ PROFIL: PELATIHAN ============
model PegawaiPelatihan {
  id              String   @id @default(cuid())
  pegawaiId       String
  namaPelatihan   String
  penyelenggara   String
  tahun           String
  pegawai         Pegawai  @relation(fields: [pegawaiId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============ PROFIL: DOKUMEN ============
model PegawaiDokumen {
  id              String   @id @default(cuid())
  pegawaiId       String
  namaDokumen     String
  jenisDokumen    String   // KTP, Ijazah, SK, dl
  fileUrl         String
  pegawai         Pegawai  @relation(fields: [pegawaiId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============ NOTIFIKASI ============
model Notifikasi {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
model AuditLog {
  id          String   @id @default(cuid())
  userId      String
  userEmail   String
  userRole    String
  action      String   // CREATE | UPDATE | DELETE | LOGIN | LOGOUT | EXPORT
  module      String   // pegawai | payroll | cuti | absensi | shift | lembur | pph21 | dll
  targetId    String?  // ID record yang diubah (opsional)
  targetName  String?  // Nama/deskripsi record
  oldData     Json?    // Snapshot data sebelum diubah
  newData     Json?    // Snapshot data sesudah diubah
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([module])
  @@index([action])
  @@index([createdAt])
}

// ============ SHIFT KERJA ============
model Shift {
  id          String   @id @default(cuid())
  nama        String   // "Shift Pagi", "Shift Siang", "Shift Malam"
  kode        String   @unique // "A", "B", "C"
  jamMasuk    String   // "06:00"
  jamKeluar   String   // "14:00"
  durasiJam   Int      // 8
  keterangan  String?
  aktif       Boolean  @default(true)
  jadwal      JadwalShift[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model JadwalShift {
  id          String   @id @default(cuid())
  pegawaiId   String
  shiftId     String
  tanggal     DateTime // Tanggal spesifik jadwal ini berlaku
  pegawai     Pegawai  @relation(fields: [pegawaiId], references: [id])
  shift       Shift    @relation(fields: [shiftId], references: [id])
  createdAt   DateTime @default(now())

  @@unique([pegawaiId, tanggal])
  @@index([tanggal])
}

// ============ LEMBUR ============
model Lembur {
  id              String        @id @default(cuid())
  pegawaiId       String
  tanggal         DateTime
  jamMulai        String        // "17:00"
  jamSelesai      String        // "20:00"
  durasiJam       Float         // 3.0
  jenis           JenisLembur   @default(HARI_KERJA)
  alasan          String
  status          StatusLembur  @default(PENDING)
  disetujuiOleh  String?
  tarifPerJam     Decimal       @default(0)
  totalBayar      Decimal       @default(0)
  catatan         String?
  pegawai         Pegawai       @relation(fields: [pegawaiId], references: [id])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([pegawaiId])
  @@index([tanggal])
  @@index([status])
}

enum JenisLembur {
  HARI_KERJA
  HARI_LIBUR
  HARI_BESAR
}

enum StatusLembur {
  PENDING
  APPROVED
  REJECTED
}

// ============ PPH 21 ============
model PPh21 {
  id              String   @id @default(cuid())
  pegawaiId       String
  periode         DateTime // Bulan dan tahun (simpan sbg tanggal-1 bulan tsb)
  gajiPokok       Decimal
  tunjangan       Decimal
  lemburBayar     Decimal  @default(0)
  penghasilanBruto Decimal
  biayaJabatan    Decimal  // 5% max 500.000
  iuranPensiunEmp Decimal  @default(0)
  penghasilanNetto Decimal
  ptkpKode        String   // "TK/0", "K/1", "K/2", "K/3"
  ptkpNilai       Decimal
  pkp             Decimal  // Penghasilan Kena Pajak
  pph21Setahun    Decimal  // PKP x tarif progresif
  pph21Sebulan    Decimal  // pph21Setahun / 12
  metodePotong    MetodePPh21 @default(GROSS)
  pegawai         Pegawai  @relation(fields: [pegawaiId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([pegawaiId, periode])
  @@index([periode])
}

enum MetodePPh21 {
  GROSS           // Dipotong dari gaji pegawai
  GROSS_UP        // Ditanggung perusahaan (dinaikkan)
  NET             // Netto - perusahaan tanggung seluruh pajak
}

// ============ IMPORT FINGERPRINT ============
model ImportFingerprint {
  id            String              @id @default(cuid())
  namaFile      String
  totalRecord   Int
  berhasil      Int                 @default(0)
  gagal         Int                 @default(0)
  status        StatusImport        @default(PROCESSING)
  errorLog      Json?               // Array of { row, nik, error }
  uploadedBy    String
  absensi       Absensi[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}

enum StatusImport {
  PROCESSING
  SELESAI
  GAGAL
}

// ============ KONTRAK PEGAWAI (NEW) ============
model Kontrak {
  id              String        @id @default(cuid())
  pegawaiId       String
  tipe            TipeKontrak   // PKWT | MAGANG
  nomorKontrak    String?       // Nomor dokumen kontrak
  tanggalMulai    DateTime
  tanggalSelesai  DateTime
  durasiHari      Int           // hitung otomatis
  posisi          String        // jabatan/posisi selama kontrak
  unitKerja       String        // unit/bidang penempatan
  gajiKontrak     Decimal       @default(0)
  tunjangan       Decimal       @default(0)
  status          StatusKontrak @default(AKTIF)
  catatanPerpanjang String?
  diperpanjangDari  String?     // id kontrak sebelumnya jika perpanjangan
  reminder14Sent  Boolean       @default(false) // flag reminder 14 hari sudah kirim
  reminder7Sent   Boolean       @default(false) // flag reminder 7 hari sudah kirim
  keterangan      String?
  pegawai         Pegawai       @relation(fields: [pegawaiId], references: [id])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([pegawaiId])
  @@index([tanggalSelesai])
  @@index([status])
}

enum TipeKontrak {
  PKWT    // Perjanjian Kerja Waktu Tertentu
  MAGANG  // Magang / Internship
}

enum StatusKontrak {
  AKTIF
  SELESAI
  DIPERPANJANG
  DIBATALKAN
}

enum MetodeAbsensi {
  SELFIE
  FINGERPRINT
  GPS
  MANUAL
}

// ============ PENUKARAN POIN (REWARD) ============
model PenukaranPoin {
  id              String          @id @default(cuid())
  pegawaiId       String
  tanggal         DateTime        @default(now())
  jumlahPoin      Int             // Jumlah poin yang dipotong
  keteranganItem  String          // "Voucher Belanja Rp 100.000"
  status          StatusPenukaran @default(PENDING)
  approvedById    String?
  pegawai         Pegawai         @relation(fields: [pegawaiId], references: [id])
  approvedBy      Pegawai?        @relation("PoinApprovedBy", fields: [approvedById], references: [id])
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([pegawaiId])
  @@index([status])
}

enum StatusPenukaran {
  PENDING
  APPROVED
  REJECTED
}
